include README.md
include AGENTS.md
include LICENSE
include MANIFEST.in
include requirements.txt
include requirements-*.txt
recursive-include animedex *.json *.yml *.yaml

# build_info.py is generated by ``tools/generate_build_info.py`` and
# .gitignore'd. Without an explicit include here it would be excluded
# from sdists (setuptools' default sdist content is tracked + manifested
# files only). The wheel already picks it up via ``find_packages`` as
# long as the file exists at build time, but listing it here too means
# both formats carry the same per-build metadata.
include animedex/config/build_info.py

recursive-include plans *.md
